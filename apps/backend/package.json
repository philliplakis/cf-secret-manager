{
  "name": "backend",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun src/index.ts",
    "typecheck": "tsgo --noEmit",
    "clean": "rm -rf dist",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.14",
    "@better-auth/drizzle-adapter": "1.6.11",
    "@cfsm/core": "workspace:*",
    "@cfsm/types": "workspace:*",
    "better-auth": "1.6.11",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23"
  },
  "devDependencies": {
    "@cfsm/tsconfig": "workspace:*",
    "@cloudflare/workers-types": "^4.20260607.1",
    "@types/bun": "^1.2.18",
    "@types/node": "^25.9.2",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "wrangler": "^4.98.0"
  }
}
